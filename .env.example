# BrainFlow Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# SECURITY - REQUIRED FOR PRODUCTION
# =============================================================================

# Master API token for authentication
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
NEUROLINKED_API_TOKEN=

# Require authentication for all API endpoints (except health check)
NEUROLINKED_REQUIRE_AUTH=true

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Environment mode: development or production
NEUROLINKED_ENV=development

# Server bind address (use 127.0.0.1 for localhost-only)
NEUROLINKED_HOST=127.0.0.1

# Server port
NEUROLINKED_PORT=8000

# =============================================================================
# CORS CONFIGURATION
# =============================================================================

# Comma-separated list of allowed origins
# For production, restrict to your domain:
# NEUROLINKED_CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
NEUROLINKED_CORS_ORIGINS=http://localhost:8000

# =============================================================================
# RATE LIMITING
# =============================================================================

# Enable rate limiting
NEUROLINKED_RATE_LIMIT=true

# Maximum requests per window
NEUROLINKED_RATE_LIMIT_REQUESTS=100

# Window duration in seconds
NEUROLINKED_RATE_LIMIT_WINDOW=60

# =============================================================================
# MCP SERVER CONFIGURATION
# =============================================================================

# URL of the BrainFlow server (for MCP server)
NEUROLINKED_URL=http://localhost:8000

# Alternative: Path to file containing API token
# NEUROLINKED_TOKEN_FILE=/path/to/token.txt

# =============================================================================
# P1: KNOWLEDGE STORE RETENTION
# =============================================================================

# Maximum entries in knowledge store (oldest auto-pruned)
NEUROLINKED_KNOWLEDGE_MAX_ENTRIES=10000

# Delete entries older than N days
NEUROLINKED_KNOWLEDGE_RETENTION_DAYS=90

# =============================================================================
# P1: SCREEN OBSERVER PRIVACY
# =============================================================================

# Window titles to exclude from screen capture (comma-separated keywords)
NEUROLINKED_SCREEN_EXCLUDED_TITLES=password,pass,secret,login,credential,bitwarden,1password,lastpass,dashlane

# =============================================================================
# P1: DISTRIBUTED RATE LIMITING
# =============================================================================

# Redis URL for distributed rate limiting (leave empty for in-memory)
# NEUROLINKED_REDIS_URL=redis://localhost:6379/0

# =============================================================================
# P1: ACTIVITY LOG RETENTION
# =============================================================================

# Maximum activity log entries (ClaudeBridge)
NEUROLINKED_ACTIVITY_LOG_MAX=1000

# =============================================================================
# P1: PROMETHEUS METRICS
# =============================================================================

# Enable metrics endpoint
NEUROLINKED_METRICS_ENABLED=false

# Metrics server port
NEUROLINKED_METRICS_PORT=9090

# =============================================================================
# P1: DETERMINISM
# =============================================================================

# Set for reproducible runs (testing, debugging)
# NEUROLINKED_SEED=42
